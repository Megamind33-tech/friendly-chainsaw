    "match.id": null,
    "match.sport": null,
    "match.competition": null,
    "match.round": null,
    "match.venue": null,
    "match.status": null,
    "match.clock": null,
    "match.period": null,
    "home.id": null,
    "home.name": null,
    "home.shortName": null,
    "home.logo": null,
    "home.score": null,
    "home.colourPrimary": null,
    "home.colourSecondary": null,
    "away.id": null,
    "away.name": null,
    "away.shortName": null,
    "away.logo": null,
    "away.score": null,
    "away.colourPrimary": null,
    "away.colourSecondary": null
