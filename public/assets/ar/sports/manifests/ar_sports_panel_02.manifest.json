    "CONTENT_SURFACE",
    "INNER_FRAME",
    "OUTER_FRAME_FRONT",
    "OUTER_FRAME_REAR",
    "SIDE_DEPTH_LEFT",
    "SIDE_DEPTH_RIGHT",
    "TOP_TRIM",
