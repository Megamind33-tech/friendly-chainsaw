    "BASE_TOP",
    "BASE_MIDDLE",
    "BASE_BOTTOM"
  ],
  "colourGroups": [
    "content",
    "framePrimary",
    "frameSecondary",
    "base",
    "accent",
    "emissive"
  ],
  "contentZones": [
