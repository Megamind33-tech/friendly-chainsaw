{
  "manifestVersion": "1.0.0",
  "id": "ar_sports_panel_02",
  "name": "Sports AR Panel 02",
  "version": "1.0.0",
  "description": "Wide hexagonal panel with a full left point, tilted stance, glow along the top edge, rounded plinth.",
  "category": "AR 3D Models",
  "subcategory": "Sports Graphics",
  "model": {
    "format": "glb",
    "path": "models/ar_sports_panel_02.glb",
    "units": "metres",
    "upAxis": "Y",
    "pivot": "base-centre"
  },
  "thumbnail": {
    "path": "thumbnails/ar_sports_panel_02.png"
  },
  "capabilities": {
