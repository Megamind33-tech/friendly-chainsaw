  "animations": {
    "entrance": [
      "fadeIn",
      "slideUp",
      "slideLeft",
      "slideRight",
      "scaleIn",
      "rotateIn",
      "riseFromFloor",
      "frameAssemble",
      "baseFirst",
      "panelReveal",
      "lightSweepReveal"
    ],
    "emphasis": [
      "scoreFlash",
      "goalPulse",
      "cardAlert",
      "statHighlight",
      "softGlow",
      "teamColourSweep",
      "dataUpdatePulse",
      "playerFocus"
    ],
    "exit": [
      "fadeOut",
      "slideDown",
      "slideLeft",
      "slideRight",
      "scaleOut",
      "frameDisassemble",
      "lowerIntoFloor",
      "lightFade"
