  "performance": {
    "defaultTier": "standard",
    "tiers": [
      "low",
      "standard",
      "high"
    ]
  },
  "updateBehaviour": {
    "default": "smoothTransition",
    "options": [
      "immediate",
      "smoothTransition",
      "numberRoll",
      "fadeReplace",
      "slideReplace",
      "scoreFlash",
      "goalAnimation",
      "statPulse",
      "none"
    ],
    "repeatSuppression": true
  },
  "validation": {
    "score": {
      "type": "integer",
      "min": 0
    },
    "clock": {
      "pattern": "^\\d{1,3}:\\d{2}$"
    },
    "colours": {
      "type": "hex"
    },
    "images": {
      "type": "url"
    },
    "onInvalid": "fallback"
  },
  "fallbacks": {
    "text": "",
    "number": 0,
    "image": "",
    "colour": "#FFFFFF"
  }
