{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Broadcast Graphics Engine",
  "version": "0.1.0",
  "identifier": "com.broadcastengine.app",
  "build": {
    "beforeDevCommand": "node scripts/ensure-dev-server.mjs",
    "devUrl": "http://localhost:1423",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "control-room",
        "title": "Broadcast Graphics Engine — Control Room",
        "width": 1600,
        "height": 1000,
        "minWidth": 1024,
        "minHeight": 700,
        "resizable": true,
        "url": "/",
        "additionalBrowserArgs": "--remote-debugging-port=9222 --disable-features=msWebOOUI,msPdfOOUI,msSmartScreenProtection"
      },
      {
        "label": "program",
        "title": "Program Output",
        "width": 1920,
        "height": 1080,
        "resizable": true,
        "decorations": false,
        "transparent": true,
        "url": "/#/program"
      },
      {
        "label": "preview",
        "title": "Preview",
        "width": 960,
        "height": 540,
        "resizable": true,
        "url": "/#/preview"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
