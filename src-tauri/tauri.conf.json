{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Broadcast Graphics Engine",
  "version": "0.1.0",
  "identifier": "com.broadcastengine.app",
  "build": {
    "beforeDevCommand": "node scripts/ensure-dev-server.mjs",
    "devUrl": "http://localhost:1423",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "control-room",
        "title": "Broadcast Graphics Engine — Control Room",
        "width": 1600,
        "height": 1000,
        "minWidth": 1024,
        "minHeight": 700,
        "resizable": true,
        "url": "/",
        "additionalBrowserArgs": "--remote-debugging-port=9222 --disable-features=msWebOOUI,msPdfOOUI,msSmartScreenProtection"
      },
      {
        "label": "program",
        "title": "Program Output",
        "width": 1920,
        "height": 1080,
        "resizable": true,
        "decorations": false,
        "transparent": true,
        "url": "/#/program"
      },
      {
        "label": "preview",
        "title": "Preview",
        "width": 960,
        "height": 540,
        "resizable": true,
        "url": "/#/preview"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "publisher": "Broadcast Graphics Engine",
    "shortDescription": "Software-Defined Broadcast Graphics Engine",
    "longDescription": "GFX, virtual sets, AR, sports scorebugs, playout, NDI, and OBS output — an integrated broadcast graphics stack that runs on a single machine.",
    "homepage": "https://github.com/Megamind33-tech/friendly-chainsaw",
    "category": "Video",
    "copyright": "© Broadcast Graphics Engine contributors",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "wix": {
        "language": ["en-US"],
        "upgradeCode": "9F8B6A17-3D2E-4F9C-BEE1-8A2C46B7A101"
      },
      "nsis": {
        "installMode": "perMachine"
      },
      "digestAlgorithm": "sha256",
      "timestampUrl": "http://timestamp.digicert.com"
    },
    "macOS": {
      "frameworks": [],
      "minimumSystemVersion": "11.0"
    },
    "linux": {
      "deb": {
        "depends": [
          "libgtk-3-0t64 | libgtk-3-0",
          "libwebkit2gtk-4.1-0",
          "libayatana-appindicator3-1"
        ]
      }
    }
  }
}
